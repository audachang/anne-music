# Replace api.example.org with the HTTPS hostname that points to braina-aclexp.
# This file belongs in /etc/nginx/sites-available/anne-music-search, symlinked
# into /etc/nginx/sites-enabled/.
server {
    listen 80;
    server_name api.example.org;

    location /api/search-topic {
        proxy_pass http://127.0.0.1:8765/api/search-topic;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
